# ──────────────────────────────────────────────
# PostgreSQL / TimescaleDB
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/robo

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────
# Bybit Testnet
# Para obter as chaves: https://testnet.bybit.com → API Management
# ──────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# ──────────────────────────────────────────────
# Ambiente
# ──────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
